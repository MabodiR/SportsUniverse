APP_NAME=SportsUniverse
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
MOBILE_APP_APPLE_TEAM_ID=
MOBILE_APP_ANDROID_SHA256_CERT_FINGERPRINT=
MOBILE_APP_ANDROID_MINIMUM_VERSION=1.0.0
MOBILE_APP_ANDROID_LATEST_VERSION=1.0.0
MOBILE_APP_IOS_MINIMUM_VERSION=1.0.0
MOBILE_APP_IOS_LATEST_VERSION=1.0.0
MOBILE_APP_RELEASE_NOTES="Android development build 1.0.0 (version code 3)"

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_WRITE_HOST=127.0.0.1
DB_READ_HOSTS=127.0.0.1
DB_PORT=5432
DB_DATABASE=sportuniverse
DB_USERNAME=sportuniverse
DB_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
MEDIA_DISK=media
MEDIA_REQUIRES_MODERATION=false
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false
MEDIA_ACCESS_KEY_ID=
MEDIA_SECRET_ACCESS_KEY=
MEDIA_REGION=us-east-1
MEDIA_BUCKET=
MEDIA_ENDPOINT=
MEDIA_CDN_URL=
MEDIA_PATH_STYLE=false

SCALE_REDIS_COUNTERS=false
FEED_CACHE_SECONDS=120
RECOMMENDATION_FEED_SIZE=500
RECOMMENDATION_ACTIVE_DAYS=14
VIDEO_VIEWS_TABLE=video_view_events

OPENSEARCH_HOST=http://127.0.0.1:9200
OPENSEARCH_HOSTS=http://127.0.0.1:9200
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=
OPENSEARCH_VERIFY_SSL=true
OPENSEARCH_PROFILE_INDEX=sportuniverse_profiles_v1
DISCOVERY_DRIVER=opensearch

FFMPEG_BINARY=/usr/local/bin/ffmpeg
FFPROBE_BINARY=/usr/local/bin/ffprobe
MEDIA_MAX_IMAGE_KB=10240
MEDIA_MAX_VIDEO_KB=512000
MEDIA_MAX_DOCUMENT_KB=20480

VITE_APP_NAME="${APP_NAME}"

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
