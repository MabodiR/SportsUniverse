{
  "expo": {
    "name": "SportsUniverse",
    "slug": "sports-universe",
    "scheme": "sportuniverse",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-notifications",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "SportsUniverse accesses photos and videos only when you choose media to upload."
        }
      ],
      "@config-plugins/react-native-webrtc",
      "expo-web-browser",
      "expo-video",
      "expo-status-bar"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sportuniverse.mobile",
      "associatedDomains": [
        "applinks:sportsuniverse.co.za",
        "applinks:www.sportsuniverse.co.za"
      ],
      "infoPlist": {
        "NSCameraUsageDescription": "SportsUniverse uses your camera when you choose to broadcast live sport.",
        "NSMicrophoneUsageDescription": "SportsUniverse uses your microphone when you choose to broadcast live sport."
      },
      "bitcode": false
    },
    "android": {
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.INTERNET",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.WAKE_LOCK",
        "android.permission.BLUETOOTH"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.sportuniverse.mobile",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "sportsuniverse.co.za",
              "pathPrefix": "/feed"
            },
            {
              "scheme": "https",
              "host": "sportsuniverse.co.za",
              "pathPrefix": "/@"
            },
            {
              "scheme": "https",
              "host": "sportsuniverse.co.za",
              "pathPrefix": "/clubs"
            },
            {
              "scheme": "https",
              "host": "sportsuniverse.co.za",
              "pathPrefix": "/opportunities"
            },
            {
              "scheme": "https",
              "host": "sportsuniverse.co.za",
              "pathPrefix": "/live"
            },
            {
              "scheme": "https",
              "host": "sportsuniverse.co.za",
              "pathPrefix": "/posts"
            },
            {
              "scheme": "https",
              "host": "sportsuniverse.co.za",
              "pathPrefix": "/password/reset"
            },
            {
              "scheme": "https",
              "host": "sportsuniverse.co.za",
              "pathPrefix": "/api/v1/auth/email/verify"
            },
            {
              "scheme": "https",
              "host": "www.sportsuniverse.co.za",
              "pathPrefix": "/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f15e2c0f-efec-43ad-a4bc-4f3b705235a7"
      }
    },
    "owner": "imaginativetechs-team",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/f15e2c0f-efec-43ad-a4bc-4f3b705235a7"
    }
  }
}
