{
  "expo": {
    "name": "SportUniverse",
    "slug": "sportuniverse-mobile",
    "scheme": "sportuniverse",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "SportUniverse accesses photos and videos only when you choose media to upload."
        }
      ],
      "@config-plugins/react-native-webrtc",
      "expo-web-browser",
      "expo-video"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sportuniverse.mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "SportUniverse uses your camera when you choose to broadcast live sport.",
        "NSMicrophoneUsageDescription": "SportUniverse uses your microphone when you choose to broadcast live sport."
      }
    },
    "android": {
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.sportuniverse.mobile"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
